# direnv configuration for tinyland-goo
# Usage: direnv allow

# Load the Nix devShell from flake.nix
use flake

# Load .env files if present (.env then .env.local override)
dotenv_if_exists .env
dotenv_if_exists .env.local

# Local-only operator overrides (endpoints, tokens) — never committed.
dotenv_if_exists .envrc.local

# Add scripts/ to PATH if it exists
if [ -d scripts ]; then
  PATH_add scripts
fi

# Reload direnv when these change
watch_file flake.nix
watch_file flake.lock
watch_file package.json

# Defaults
export NODE_ENV="${NODE_ENV:-development}"
export SITE_BASE_URL="${SITE_BASE_URL:-http://localhost:5173}"
